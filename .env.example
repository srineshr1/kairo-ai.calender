# Frontend Environment Variables
# Copy this file to .env for local development

# Groq Configuration
# Required for AI chat + WhatsApp extraction
VITE_GROQ_API_KEY=your_groq_api_key

# WhatsApp Bridge Configuration
# URL where the WhatsApp bridge server is running (default: http://localhost:3001)
VITE_BRIDGE_URL=http://localhost:3001

# Bridge server polling interval in milliseconds (default: 3000)
VITE_POLL_INTERVAL=3000

# Supabase Configuration
# Get these from your Supabase project settings (https://app.supabase.com)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Authentication Configuration
# Set to 'true' to require authentication even in development (default: false)
# In production, auth is always required
VITE_REQUIRE_AUTH=false
